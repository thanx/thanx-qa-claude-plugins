{
  "name": "thanx-qa-claude-plugins",
  "version": "0.1.0",
  "description": "Thanx QA Chapter - Claude Code Plugin Marketplace",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint:md": "markdownlint '**/*.md' --ignore node_modules",
    "lint:md:fix": "markdownlint '**/*.md' --ignore node_modules --fix",
    "test:links": "node tests/link-checker.js",
    "test:schema": "jest tests/schema-validation.test.js",
    "test:all": "npm run lint:md && npm run test:links && npm test",
    "validate": "claude plugin validate ."
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "markdown-link-check": "^3.12.1",
    "markdownlint-cli": "^0.39.0"
  },
  "overrides": {
    "marked": "^12.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
